CREATE DATABASE employeemanagement;
USE employeemanagement;

-- TABLE 1
CREATE TABLE Department (
   DeptID INT PRIMARY KEY,
   DeptName VARCHAR(50),
   Location VARCHAR(50)
);

INSERT INTO Department VALUES
