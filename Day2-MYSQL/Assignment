CREATE VIEW EmployeeDetails AS
SELECT e.EmpID,e.EmpName,d.DeptName,e.Salary
FROM Employee e
JOIN Department d
ON e.DeptID = d.DeptID;
SELECT * FROM EmployeeDetails;

