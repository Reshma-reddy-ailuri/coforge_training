-- EQUI JOIN
select a.agent_name,c.customer_name,c.customer_area
FROM agents a JOIN customers c
ON a.working_area=c.customer_area;
-- NON EQUI JOIN
select a.agent_name,c.customer_name,c.customer_area
FROM agents a JOIN customers c
ON a.working_area <> c.customer_area;
-- INNER JOIN
select a.agent_name,c.customer_name,c.customer_area
FROM agents a inner JOIN customers c
ON a.working_area=c.customer_area;

