USE training;
CREATE table tbl_employee(
	eid INT,
    ename VARCHAR(50),
    esalary INT,
    dno INT
);

DESC tbl_employee;

insert into tbl_employee values
(101,'Reshma',10000,10),
(102,'Srima',20000,20),
(103,'Keerthi',30000,10),
(104,'Abhi',30000,20);

truncate table tbl_employee;
SELECT * 
FROM tbl_employee;

-- number of employees in each dept using GROUP BY.
SELECT dno,count(*)
FROM tbl_employee
group by dno;

-- using alias(AS) to rename 
SELECT dno,count(*) as "total number of employees"
FROM tbl_employee
group by dno;

-- USING AGGREGATION FUNCTIONS (group functions)
SELECT dno,SUM(esalary),AVG(esalary),MIN(esalary),MAX(esalary)
FROM tbl_employee
group by dno;

-- using HAVING(it is used to apply conditions in case of GROUPBY)
SELECT dno,SUM(esalary),AVG(esalary),MIN(esalary),MAX(esalary)
FROM tbl_employee
group by dno
having min(esalary)>10000;

-- order by is a class which is used to sort values in ascending or descending order ,by default it is ascending order.
SELECT dno,SUM(esalary),AVG(esalary),MIN(esalary),MAX(esalary)
FROM tbl_employee
group by dno
order by dno Asc;
-- IN SQL,ORDER BY QUERY MUST BE THE LAST QUERY IN SELECT STATEMENT,ELSE YOU WILL GET SYNTAX ERROR.

-- ORDER BY is a common keyword THAT CAN BE USED IN NORMAL select queries also,it's not mandatory that IT SHOULD BE ALONG WITH GROUP BY.
SELECT *
FROM tbl_employee
ORDER BY eid DESC;

--  SUBQUERY

CREATE TABLE tbl_department(
	dno INT,
    dname VARCHAR(50)
);

INSERT INTO tbl_department VALUES
(10,'Development'),
(20,'Testing');    

SELECT * from tbl_department;

-- SUBQUERY is a query inside another query.
-- printing dname which is linked to eid=101.
SELECT dname from tbl_department
where dno=(SELECT dno from tbl_employee where eid=101);

-- displaying values where dname is testing.
select * from tbl_employee
where dno=(SELECT dno from tbl_department where dname='Testing');

-- displaying dname of specified employee
select dname  from tbl_department
where dno=(SELECT dno from tbl_employee where ename='Srima');

-- IF THE  INNER QUERY IS RETURNING ONLY ONE VALUE THEN IT IS CALLED AS "SINGLE ROW SUB QUERY(SRSQ)".
-- IF THE INNER QUERY IS RETURNING MULTIPLE VALUES THEN IT IS CALLED AS "MULTI-ROW SUB QUERY".
-- you should use IN OR NOT IN for multi row sub query unlike = in Single row sub query (in first select statement after where common key " ")

SELECT dname from tbl_department where dno IN
(SELECT dno from tbl_employee where eid= 101 or eid=102);

drop table tbl_employee;

