-- PLSQL=PROCEDURAL LANGUGAGE STRUCTURED QUERY LANGUAGE.
/*
PL+SQL--.EXTENSION OF SQL
=>COMBINES SQL WITH PROGRAMMING FEATURES(LIKE VARIABLES,LOOPS,FUNCTIONS ETC.,)
=>PL is not a coding language
=>Procedure is a reusable block of code that performs a specific task.
=>A Stored Procedure is a pre-written collection of SQL statements that is saved inside the database and can be executed whenever needed.
=>for inserting values use  CALL procedure name (values)
=> "in" is used for PASS DATA INTO THE PROCEDURE from user
=> " out" means the procedure returns the result
=>"SELECT .... INTO" means saying save this value in this variable
=> BEGIN...END HERE we will have the body of the code*/


DELIMITER //
create procedure insertEmployee(in eid int,in ename varchar(20),in esalary int, in dno int)
begin
	INSERT INTO  tbl_employee (eid,ename,esalary,dno) 
    values (eid,ename,esalary,dno);
end //    
call insertEmployee(101,'Reshma',20000,10);
drop procedure insertEmployee;
select * from tbl_employee;

-- we use delimiter because in sql we end statements with ';' but in procedure we use ; inside statement so for it to understand we give seperate delimiter so that it can understand that it is end of statement.
-- STORED PROCEDURE WITH OUT code
DELIMITER //
CREATE procedure getEmployeeName(in empid integer,out empname varchar(20))
begin
	select ename into empname from tbl_employee where eid=empid;
end //

-- @EMPNAME HERE IS session variable.
call getEmployeeName (101, @empname);
select @empname;    


-- FUNCTION: 

/* 
DETERMINISTIC MEANS: For the same input, the function always returns the same output.
DECLARE=CREATE A LOCAL VARIABLE
To call a function,unlike procedure we don't use "call" we use "return"
Function : Must return exactly one value, It Computes and returns a value.
=> Function Typically uses only input parameters and returns one value */

DELIMITER //
CREATE FUNCTION getEmpName(empid integer) returns varchar(20) deterministic
begin 
	declare empname varchar(20);
    select ename into empname from tbl_employee where eid=empid;
    return empname;
end //    
SELECT getEmpName(101);

